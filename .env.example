# ============================================================
# VoiceNova AI — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ── REQUIRED (minimum to run) ──────────────────────────────
# Default path: local/offline model server such as Ollama / LM Studio / vLLM

# ── SERVER ─────────────────────────────────────────────────
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
PUBLIC_BASE_URL=https://your-public-url.ngrok-free.app
API_SECRET_KEY=change_this_to_a_random_32char_string

# ── TELEPHONY (needed for real calls) ──────────────────────
# Get from: console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+91XXXXXXXXXX

# Optional Plivo alternative
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_PHONE_NUMBER=

# ── LLM CONFIG ─────────────────────────────────────────────
LLM_PROVIDER=local              # local | openai | anthropic | google
LLM_MODEL=gemma:2b
LLM_API_URL=http://127.0.0.1:11434/api/chat
LLM_MAX_TOKENS=300
LLM_TEMPERATURE=0.7
LLM_API_FORMAT=ollama          # auto | openai | ollama
LLM_REQUEST_TIMEOUT_MS=120000

# Offline profile options:
# 1. Qwen 2.5 1.5B via Ollama (best budget default)
# LLM_PROVIDER=local
# LLM_MODEL=qwen2.5:1.5b
# LLM_API_URL=http://127.0.0.1:11434/api/chat
# LLM_API_FORMAT=ollama
#
# 2. Gemma 2B via Ollama (smallest English-first option)
# LLM_PROVIDER=local
# LLM_MODEL=gemma:2b
# LLM_API_URL=http://127.0.0.1:11434/api/chat
# LLM_API_FORMAT=ollama
#
# 3. Llama 3.2 3B via Ollama (better quality, slightly heavier)
# LLM_PROVIDER=local
# LLM_MODEL=llama3.2:3b
# LLM_API_URL=http://127.0.0.1:11434/api/chat
# LLM_API_FORMAT=ollama
#
# 4. Qwen 2.5 1.5B Hugging Face checkpoint served locally through
#    an OpenAI-compatible local server such as LM Studio, vLLM, llama.cpp, or TGI:
# LLM_PROVIDER=local
# LLM_MODEL=Qwen/Qwen2.5-1.5B-Instruct
# LLM_API_URL=http://127.0.0.1:8000/v1/chat/completions
# LLM_API_FORMAT=openai
#
# 5. Llama 3.2 3B Hugging Face checkpoint served locally through
#    an OpenAI-compatible local server:
# LLM_PROVIDER=local
# LLM_MODEL=meta-llama/Llama-3.2-3B-Instruct
# LLM_API_URL=http://127.0.0.1:8000/v1/chat/completions
# LLM_API_FORMAT=openai
#
# Optional older profile:
# LLM_PROVIDER=local
# LLM_MODEL=sarvamai/sarvam-1
# LLM_API_URL=http://127.0.0.1:8000/v1/chat/completions
# LLM_API_FORMAT=openai

# Optional cloud fallback
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_KEY

# ── SPEECH TO TEXT ─────────────────────────────────────────
# Offline default (Vosk). Download a model (e.g., small-en-us) into ./models/vosk
STT_PROVIDER=vosk               # vosk | google | azure | openai_whisper
VOSK_MODEL_PATH=./models/vosk
VOSK_SAMPLE_RATE=16000
# If you choose cloud STT, set the key and switch provider:
GOOGLE_SPEECH_KEY=

# ── TEXT TO SPEECH ─────────────────────────────────────────
TTS_PROVIDER=piper              # piper | macos_say | elevenlabs | google | azure | twilio_basic
PIPER_BIN=piper                 # path to piper executable
PIPER_MODEL_PATH=./models/piper/en_US-amy-medium.onnx
PIPER_SAMPLE_RATE=16000
# On macOS, you can use the built-in offline voice instead:
# TTS_PROVIDER=macos_say
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Google TTS alternative (good for Indian languages)
# TTS_PROVIDER=google
# GOOGLE_TTS_KEY=your_google_cloud_api_key

# ── DATABASE ───────────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://db:5432/voicenova
DATABASE_USER=vnova
DATABASE_PASSWORD=change_this_password
DATABASE_POOL_SIZE=10

# ── REDIS (session + cache) ────────────────────────────────
REDIS_URL=redis://cache:6379

# ── STORAGE (call recordings + knowledge base) ─────────────
STORAGE_PROVIDER=local          # local | s3 | minio
STORAGE_PATH=./storage          # for local storage

# AWS S3 (optional)
# STORAGE_PROVIDER=s3
# AWS_ACCESS_KEY=AKIA...
# AWS_SECRET_KEY=your_secret
# AWS_BUCKET=voicenova-calls
# AWS_REGION=ap-south-1

# ── AGENT DEFAULTS ─────────────────────────────────────────
DEFAULT_LANGUAGE=hi-IN
AUTO_DETECT_LANGUAGE=true
AGENT_RESPONSE_TIMEOUT_MS=8000
MAX_CALL_DURATION_MINUTES=30

# ── SELF-LEARNING ──────────────────────────────────────────
ENABLE_SELF_LEARNING=true
MIN_CALL_SCORE_FOR_LEARNING=4.0    # 1-5 scale
AUTO_APPROVE_LEARNING=false        # Set true to skip manual review

# ── STREAMING (lower latency) ──────────────────────────────
STREAMING_TTS=true
STREAMING_LLM=true

# ── CRM INTEGRATIONS (optional) ────────────────────────────
# SALESFORCE_CLIENT_ID=
# SALESFORCE_CLIENT_SECRET=
# HUBSPOT_API_KEY=
# ZOHO_CLIENT_ID=

# ── HR EMAIL (optional, for candidate thank-you emails) ───
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=HR Team
SMTP_USE_TLS=true

# ── MONITORING (optional) ──────────────────────────────────
ENABLE_METRICS=true
SENTRY_DSN=                        # Leave blank to disable

# ── DEVELOPMENT FLAGS ──────────────────────────────────────
DEBUG_MODE=false
LOG_LEVEL=INFO                     # DEBUG | INFO | WARN | ERROR
MOCK_TELEPHONY=true                # true = accept test calls without Twilio
